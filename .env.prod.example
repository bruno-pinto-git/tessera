# Copy to ".env" on the deploy VM (same folder as docker-compose.yml) and fill in.
# docker compose reads .env automatically. Do NOT commit the real .env.

# Public hostname the stack is served on. On Azure, set a DNS name label on the
# VM's public IP and use the free FQDN it gives you (must resolve to the VM and
# have ports 80/443 open for Let's Encrypt to issue the TLS cert).
TESSERA_FQDN=tessera.swedencentral.cloudapp.azure.com

# Keycloak's own Postgres password (internal; pick something strong).
KC_DB_PASSWORD=change-me-kc-db

# Keycloak master-realm admin password (login at https://<fqdn>/auth/admin).
KC_ADMIN_PASSWORD=change-me-kc-admin

# --- Realm secrets & seed passwords (injected into the realm import) ---
# These fill the ${...} placeholders in infra/keycloak/realm-export.json. They
# ONLY apply on a FRESH import — on a VM whose realm is already imported, change
# them in the KC admin console instead (or wipe the db-keycloak volume to re-import).
# tessera-bff is a confidential client with realm-management roles — give it a
# strong secret. Leave the IdP secrets empty to disable Google/Microsoft login.
TESSERA_BFF_CLIENT_SECRET=change-me-bff-secret
GOOGLE_IDP_CLIENT_SECRET=
MICROSOFT_IDP_CLIENT_SECRET=
# App user (tessera realm) seed passwords — set strong ones; admin is platform-admin.
SEED_ADMIN_PASSWORD=change-me-admin
SEED_GESTOR_PASSWORD=change-me-gestor
SEED_STAFF_PASSWORD=change-me-staff
SEED_ADEPTO_PASSWORD=change-me-adepto

# --- Internal infra passwords (app Postgres + RabbitMQ) ---
# Optional. They default to postgres/tessera. NOTE: only set these on a FRESH
# deploy — changing them on an existing VM needs the db-*-data / rabbitmq-data
# volumes reset, since the passwords are baked at first init. Not internet-exposed
# (internal docker network + only 80/443/22 open), so the defaults are acceptable.
# APP_DB_PASSWORD=change-me-db
# RABBITMQ_PASSWORD=change-me-rabbit

# --- Stripe card payments (OPTIONAL) ---
# Leave empty to disable card payments (the stack still boots; MB WAY mock stays
# available). To enable, paste a test-mode secret key from dashboard.stripe.com
# (Developers > API keys, "Test mode" on). The success/cancel redirect URLs are
# already set to https://<fqdn>/... by docker-compose.prod.yml, so only the key
# is needed here.
STRIPE_SECRET_KEY=
