# Tessera — variáveis de ambiente (lidas pelo docker-compose.yml)
#
# Copia para `.env` e preenche, OU corre scripts/run/demo-network.ps1 que
# detecta e escreve automaticamente. O `.env` está gitignored (é específico
# de cada rede/demo); este .env.example fica em git como referência.

# --- MB WAY (demo com mock-mbway no telemóvel que faz hotspot) ---
# Onde corre o mock-mbway. Na demo = IP do telemóvel-hotspot (o gateway da
# rede). Lê-o no ecrã da app mock, ou é o "Default Gateway" do ipconfig no PC.
MBWAY_GATEWAY_URL=http://192.168.43.1:8443

# Onde o mock faz callback (webhook). = IP do PC na rede do hotspot (o "IPv4
# Address" do ipconfig). Porta 8081 = ticket-service exposto.
MBWAY_WEBHOOK_BASE_URL=http://192.168.43.10:8081

# Constantes do protocolo SIBS (normalmente não mexer na demo).
MBWAY_TERMINAL_ID=47215
MBWAY_CLIENT_ID=tessera-mock
