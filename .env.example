# Tessera — variáveis de ambiente (lidas pelo docker-compose.yml)
#
# Copia para `.env` e preenche, OU corre scripts/run/demo-network.ps1 que
# detecta e escreve automaticamente. O `.env` está gitignored (é específico
# de cada rede/demo); este .env.example fica em git como referência.

# --- MB WAY (o mock-mbway no telemóvel faz polling a nós; nunca o contrário) ---
# Onde o mock faz callback (webhook) depois de aprovar/recusar. = IP do PC na
# rede do hotspot (o "IPv4 Address" do ipconfig). Porta 8081 = ticket-service
# exposto. Em produção, o domínio público (ex: https://<FQDN>).
MBWAY_WEBHOOK_BASE_URL=http://192.168.43.10:8081

# Constante do protocolo SIBS (normalmente não mexer na demo).
MBWAY_TERMINAL_ID=47215

# Segredo partilhado que a app mock-mbway envia no header X-Relay-Secret ao
# consultar pagamentos pendentes — o endpoint de poll fica exposto à internet
# em produção, ao contrário do que acontecia antes (só LAN).
MBWAY_RELAY_SECRET=dev-secret

# --- Stripe (pagamentos por cartão via Checkout) ---
# Conta grátis em dashboard.stripe.com, com o toggle "Test mode" ligado ->
# Developers -> API keys -> Secret key (começa por sk_test_...).
STRIPE_SECRET_KEY=sk_test_...
# Para onde a Stripe redireciona depois do pagamento (o frontend web, servido
# pelo nginx em :8000). {id}/{eventId} são substituídos automaticamente.
STRIPE_SUCCESS_URL=http://localhost:8000/events/{eventId}?stripe_ticket_id={id}
STRIPE_CANCEL_URL=http://localhost:8000/events/{eventId}?stripe_cancelled=1

# --- Google Wallet ("Adicionar ao Google Wallet" em bilhetes pagos) ---
# Issuer ID de pay.google.com/business/console.
GOOGLE_WALLET_ISSUER_ID=3388000000023170685
# Chave JSON da conta de serviço (Cloud Console > IAM > Service Accounts >
# chave > Create new key > JSON), codificada em Base64 numa única linha:
# powershell -c "[Convert]::ToBase64String([IO.File]::ReadAllBytes('chave.json'))"
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_BASE64=
