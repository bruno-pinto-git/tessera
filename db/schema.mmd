erDiagram
    event {
        BIGSERIAL id PK
        BIGINT match_id "future FK"
        VARCHAR name
        NUMERIC price_normal
        NUMERIC price_supporter
        VARCHAR status "DRAFT|PUBLISHED|SALES_CLOSED|CANCELLED"
        TIMESTAMPTZ created_at
    }

    ticket {
        BIGSERIAL id PK
        BIGINT event_id FK
        UUID code UK
        NUMERIC price
        VARCHAR status "PENDING|PAID|VALIDATED"
        VARCHAR payment_method "MBWAY|CARD|CASH"
        VARCHAR mbway_reference
        TIMESTAMPTZ created_at
        TIMESTAMPTZ payment_date
        TIMESTAMPTZ validation_date
        BIGINT validator_id "future FK"
    }

    event ||--o{ ticket : "has"
