# Production defaults for the Dockerized stack.
# These are baked into the bundle by `npm run build` inside the nginx image
# (see infra/nginx/Dockerfile). Values match the docker-compose topology:
# the SPA is served by nginx on :8000 and Keycloak is reached directly on :8180.

VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=tessera
VITE_KEYCLOAK_CLIENT_ID=tessera-web
