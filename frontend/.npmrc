# openapi-typescript@7 still declares its TypeScript peer as `^5.x`, but
# the tool only reads the YAML spec and emits .d.ts definitions — it does
# not use the TS compiler API internals. It works fine with TypeScript 6,
# which is what the rest of this project uses.
#
# Setting legacy-peer-deps lets `npm install` complete without forcing
# a TS downgrade.
legacy-peer-deps=true
