# frontend/.env.production holds non-secret production defaults for the
# Dockerized stack — versioned so `docker compose build` works out of the box.
!frontend/.env.production

# Vite
*.local

# Playwright (E2E)
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/

# Gradle / Java / Kotlin
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
# scripts/build/ holds our build PowerShell scripts, not Gradle output — keep it tracked
!scripts/build/
!scripts/build/**
local.properties

