# =====================================================================
#  07-sheet-rules.http
#  Business rules for the match sheet (P3):
#    - max 11 STARTERs per team
#    - max 12 SUBSTITUTEs per team
#    - max 5 SUBSTITUTION occurrences per team per match
#    - player sent off (RED_CARD) cannot author further occurrences
#    - FOUL is a valid occurrence type
#
#  Requires 00-auth.http + 03-teams.http + 04-players.http already executed
#  (so we have teamSeniorMId, awayTeamId, venueId, etc.).
# =====================================================================

### Setup: fresh match for these rule tests
POST {{matchServiceUrl}}/api/v1/matches
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "homeTeamId": {{teamSeniorMId}},
  "awayTeamId": {{awayTeamId}},
  "kickoffAt":  "2026-12-15T20:00:00Z"
}

> {%
client.global.set("rulesMatchId", response.body.id);
client.test("status 201", () => client.assert(response.status === 201));
%}


### Setup: create 12 home-team players (we need lots to test limits)
# We reuse playerGkId + playerFwId (2) from 04-players.http and add 10 more.
POST {{matchServiceUrl}}/api/v1/teams/{{teamSeniorMId}}/players
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "firstName": "Bulk1", "lastName": "P", "position": "DF", "shirtNumber": 2 }

> {% client.global.set("bulkP1", response.body.id); %}

