### Fill lineup with 11 STARTERs (gk + fw + 9 bulk)
# We send each one as a separate request — the test runs blocks in order.
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/lineup
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "playerId": {{playerGkId}}, "role": "STARTER" }

###
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/lineup
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "playerId": {{playerFwId}}, "role": "STARTER" }

