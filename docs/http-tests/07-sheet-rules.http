> {%
client.test("11th STARTER accepted", () => client.assert(response.status === 201));
%}


### 12th STARTER → 409 (max 11 reached)
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/lineup
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "playerId": {{bulkP10}}, "role": "STARTER" }

> {%
client.test("status 409 (max 11 starters)", () =>
    client.assert(response.status === 409));
%}


### Add same player as SUBSTITUTE instead → 201
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/lineup
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "playerId": {{bulkP10}}, "role": "SUBSTITUTE" }

> {%
client.test("status 201 (substitute ok)", () => client.assert(response.status === 201));
%}


### Cannot promote SUBSTITUTE to STARTER if 11 already STARTERs → 409
PATCH {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/lineup/{{bulkP10}}
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "role": "STARTER" }

> {%
client.test("status 409 (PATCH respects roster limit)", () =>
    client.assert(response.status === 409));
%}


### FOUL is now a valid occurrence type
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/occurrences
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "minute": 25, "type": "FOUL", "playerId": {{bulkP1}} }

> {%
client.test("FOUL accepted", () => client.assert(response.status === 201));
client.test("type stored", () =>
    client.assert(response.body.type === "FOUL"));
%}


### RED_CARD: send off bulkP1
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/occurrences
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "minute": 40, "type": "RED_CARD", "playerId": {{bulkP1}} }

> {%
client.test("status 201", () => client.assert(response.status === 201));
%}


### bulkP1 (sent off) can NOT author further occurrences → 409
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/occurrences
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "minute": 55, "type": "GOAL", "playerId": {{bulkP1}} }

> {%
client.test("status 409 (sent off)", () =>
    client.assert(response.status === 409));
%}


### Substitutions: do 5 of them, then the 6th should fail
# Sub 1: bulkP10 (sub) comes on, bulkP2 (starter) goes off
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/occurrences
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "minute": 60, "type": "SUBSTITUTION", "playerId": {{bulkP10}}, "replacedPlayerId": {{bulkP2}} }

### Sub 2: need fresh subs — add bulkP3...P7 as subs first
# Actually bulkP2..P9 are STARTERs. We need to add more SUBSTITUTEs.
# Let's add 4 more subs to the team using the players we still have.
# We are limited by team roster — let's add some more players quickly.
POST {{matchServiceUrl}}/api/v1/teams/{{teamSeniorMId}}/players
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "firstName": "Sub2", "lastName": "P", "position": "MF", "shirtNumber": 13 }

> {% client.global.set("subB", response.body.id); %}

###
POST {{matchServiceUrl}}/api/v1/matches/{{rulesMatchId}}/sheet/lineup
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "playerId": {{subB}}, "role": "SUBSTITUTE" }

### Sub 2
